{
  "name": "zoom-mynotes-sync",
  "version": "1.2.0",
  "description": "Deploy and control Zoom Notes transcript sync from Obsidian",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "install-vault": "npm run build && node scripts/install-vault.mjs"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "zoom",
    "transcripts"
  ],
  "author": "DaemonBehr",
  "repository": {
    "type": "git",
    "url": "https://github.com/script-repo/Zoom-MyNotes-Obsidian-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/script-repo/Zoom-MyNotes-Obsidian-plugin/issues"
  },
  "homepage": "https://github.com/script-repo/Zoom-MyNotes-Obsidian-plugin#readme",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "esbuild": "^0.25.0",
    "obsidian": "^1.7.2",
    "typescript": "^5.7.2"
  }
}
